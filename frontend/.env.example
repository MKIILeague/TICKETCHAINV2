# ─── Frontend environment variables (Vite) ──────────────────────────────────
# Copy this file to `.env` and fill in the values. Vite only exposes vars
# prefixed with VITE_. Restart `npm run dev` after editing.

# Pinata JWT used to pin event posters + metadata to IPFS (Event Creation Form).
# Create a free account at https://pinata.cloud, make an API key with the
# pinFileToIPFS + pinJSONToIPFS scopes, and paste the JWT here.
VITE_PINATA_JWT=
